---
layout: null
permalink: /travel/feed.xml
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <generator uri="https://jekyllrb.com/" version="{{ jekyll.version }}">Jekyll</generator>
  <link href="{{ '/travel/feed.xml' | absolute_url }}" rel="self" type="application/atom+xml" />
  <link href="{{ '/travel/' | absolute_url }}" rel="alternate" type="text/html" />
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <id>{{ '/travel/feed.xml' | absolute_url }}</id>
  <title type="html">{{ site.title | smartify | xml_escape }} Travel</title>
  <subtitle>{{ site.description | xml_escape }}</subtitle>
  <author>
    <name>{{ site.author.name | default: site.name | xml_escape }}</name>
    {% if site.author.email %}<email>{{ site.author.email | xml_escape }}</email>{% endif %}
  </author>
  {% assign travel_posts = site.travel | sort: "date" | reverse %}
  {% for post in travel_posts %}
  <entry>
    <title type="html">{{ post.title | smartify | strip_html | normalize_whitespace | xml_escape }}</title>
    <link href="{{ post.url | absolute_url }}" rel="alternate" type="text/html" title="{{ post.title | xml_escape }}" />
    <published>{{ post.date | date_to_xmlschema }}</published>
    <updated>{{ post.last_modified_at | default: post.date | date_to_xmlschema }}</updated>
    <id>{{ post.id | default: post.url | absolute_url }}</id>
    {% if post.excerpt %}
    <summary type="html">{{ post.excerpt | strip_html | normalize_whitespace | xml_escape }}</summary>
    {% endif %}
    {% assign content = post.content | markdownify %}
    {% assign content = content | replace: 'src="/', 'src="https://srj.github.io/' %}
    {% assign content = content | replace: 'href="/', 'href="https://srj.github.io/' %}
    <content type="html">{{ content | xml_escape }}</content>
  </entry>
  {% endfor %}
</feed>
